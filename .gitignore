# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---- Dependencies ----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Build output ----
/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts

# ---- Test / coverage ----
/coverage
/.nyc_output

# ---- Env (NEVER commit secrets) ----
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# ---- AI / agent local state ----
.claude/
.agents/
.aider*
skills-lock.json

# ---- Vercel ----
.vercel

# ---- Sensitive ----
*.pem
*.key
*.cert
secrets/

# ---- Privy local artifacts ----
.privy/
.next-localstorage
.localstorage
