# Privy
# Get these from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
# Optional: scope an app client per environment (prod / preview / dev).
# Leave blank if you only have one app client.
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Server-only — needed if you add API routes that verify auth tokens.
# DO NOT prefix with NEXT_PUBLIC_ (would leak to client bundle).
PRIVY_APP_SECRET=

# Solana RPC. Defaults to public mainnet if unset (rate-limited; replace
# with your own Helius / Triton / QuickNode endpoint for production).
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_WS_URL=
